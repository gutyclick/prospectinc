{
  "name": "prospector-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm lint && pnpm typecheck && pnpm test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset --local",
    "supabase:migrate": "supabase migration up --local",
    "supabase:test": "supabase test db",
    "supabase:lint": "supabase db lint --local --level error",
    "supabase:types": "node scripts/generate-supabase-types.mjs",
    "supabase:types:linked": "node scripts/generate-supabase-types.mjs --linked",
    "demo:import": "node --env-file-if-exists=.env.local scripts/import-demo-data.mjs",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy"
  },
  "packageManager": "pnpm@11.15.0",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@trigger.dev/react-hooks": "^4.5.4",
    "@trigger.dev/sdk": "^4.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.82.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "trigger.dev": "^4.5.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
